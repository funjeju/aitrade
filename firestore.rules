rules_version = '2';

// ATS-OS Firestore 보안 규칙 (docs/05 §5.7).
// 원칙: 사용자는 자기 문서만 읽기/쓰기. role/claims는 클라이언트가 못 바꾼다.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function ownsNew() {
      return isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
    }
    function ownsExisting() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    function parentStrategy(strategyId) {
      return get(/databases/$(database)/documents/strategies/$(strategyId));
    }
    function strategyExists(strategyId) {
      return exists(/databases/$(database)/documents/strategies/$(strategyId));
    }
    // 상위 전략의 소유자인지. 배치로 전략+첫버전을 동시 생성할 땐 부모가 아직 없으므로
    // (부모 미존재 || 부모 소유자==본인)로 판정한다.
    function ownsParentStrategy(strategyId) {
      return isSignedIn()
        && (!strategyExists(strategyId)
            || parentStrategy(strategyId).data.ownerUid == request.auth.uid);
    }

    // 전략: 소유자만. 생성 시 ownerUid는 본인이어야.
    match /strategies/{strategyId} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsNew();

      // 버전: 상위 전략 소유자만. (불변 — update/delete 금지)
      // 생성은 본인이 stamp한 createdBy + 부모 소유권으로 판정(배치 생성 대응).
      match /versions/{versionId} {
        allow read: if isSignedIn() && strategyExists(strategyId)
          && parentStrategy(strategyId).data.ownerUid == request.auth.uid;
        allow create: if isSignedIn()
          && request.resource.data.createdBy == request.auth.uid
          && ownsParentStrategy(strategyId);
        allow update, delete: if false;

        // 백테스트 결과
        match /backtests/{backtestId} {
          allow read, create: if isSignedIn() && strategyExists(strategyId)
            && parentStrategy(strategyId).data.ownerUid == request.auth.uid;
          allow update, delete: if false;
        }
      }
    }

    // 스캔 매치(관심종목): 소유자만. 생성 시 ownerUid는 본인.
    match /scanMatches/{matchId} {
      allow read, delete: if ownsExisting();
      allow create: if ownsNew();
      allow update: if false; // 스캔 시점 스냅샷은 불변
    }

    // AI 전략 대화 세션: 소유자만. (기기 간 유지)
    match /chatSessions/{sessionId} {
      allow read, delete: if ownsExisting();
      allow create: if ownsNew();
      allow update: if ownsExisting() && request.resource.data.ownerUid == request.auth.uid;
    }

    // 사용자 프로필: 본인만.
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // 그 외 전부 차단(명시적 화이트리스트).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
