{
  "name": "ats-os",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --filter @ats/web dev",
    "build": "pnpm --filter @ats/web build",
    "start": "pnpm --filter @ats/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "i18n:check": "pnpm --filter @ats/web i18n:check"
  }
}
